    "name": "${mod_name}",
    "description": "${description}",
    "authors": [
        "${mod_author}"
    ],
    "contact": {},
    "license": "${license}",
    "environment": "*",
    "entrypoints": {
        "main": [
            "gay.themattabase.idletickarmorstands.fabric.IdleTickArmorStandsFabric"
